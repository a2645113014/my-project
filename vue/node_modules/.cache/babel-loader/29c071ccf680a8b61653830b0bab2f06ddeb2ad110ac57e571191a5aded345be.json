{"ast":null,"code":"import * as echarts from \"echarts\";\nexport default {\n  name: \"Home\",\n  data() {\n    return {\n      user: JSON.parse(localStorage.getItem('user') || '{}'),\n      activeNames: [0],\n      notices: []\n    };\n  },\n  created() {\n    this.loadNotice();\n  },\n  mounted() {\n    this.$request.get('/goods/echarts').then(res => {\n      this.initPie(res.data);\n    });\n  },\n  methods: {\n    handleChange(val) {\n      console.log(val);\n    },\n    loadNotice() {\n      this.$request.get('/notice/selectAll').then(res => {\n        this.notices = res.data;\n      });\n    },\n    initPie(data) {\n      let chartDom = document.getElementById('main');\n      let myChart = echarts.init(chartDom);\n      let option;\n      option = {\n        title: {\n          text: '商品销量统计',\n          subtext: '饼图',\n          left: 'center'\n        },\n        tooltip: {\n          trigger: 'item'\n        },\n        series: [{\n          type: 'pie',\n          radius: '60%',\n          data: data,\n          emphasis: {\n            itemStyle: {\n              shadowBlur: 10,\n              shadowOffsetX: 0,\n              shadowColor: 'rgba(0, 0, 0, 0.5)'\n            }\n          }\n        }]\n      };\n      option && myChart.setOption(option);\n    }\n  }\n};","map":{"version":3,"names":["echarts","name","data","user","JSON","parse","localStorage","getItem","activeNames","notices","created","loadNotice","mounted","$request","get","then","res","initPie","methods","handleChange","val","console","log","chartDom","document","getElementById","myChart","init","option","title","text","subtext","left","tooltip","trigger","series","type","radius","emphasis","itemStyle","shadowBlur","shadowOffsetX","shadowColor","setOption"],"sources":["src/views/manager/Home.vue"],"sourcesContent":["<template>\r\n  <div>\r\n    <el-row :gutter=\"24\">\r\n      <el-col :span=\"24\">\r\n        <el-card style=\"margin: 10px 0\">\r\n          <div style=\"font-size: 17px;font-weight: 700\">大家好，欢迎使用本系统！</div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n\r\n    <el-row :gutter=\"10\">\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"box-card\">\r\n          <div class=\"clearfix\" style=\"margin-bottom: 20px\">\r\n            <span style=\"font-size: 20px;font-weight: bold\">公告信息</span>\r\n          </div>\r\n          <div class=\"text item\">\r\n            <el-collapse v-model=\"activeNames\" @change=\"handleChange\">\r\n              <el-collapse-item :title=\"item.name\" :name=\"index\" v-for=\"(item,index) in notices\" :key=\"index\">\r\n                <div>{{item.content}}</div>\r\n              </el-collapse-item>\r\n            </el-collapse>\r\n          </div>\r\n        </el-card>\r\n      </el-col>\r\n\r\n      <el-col :span=\"12\">\r\n        <el-card class=\"box-card\">\r\n          <div id=\"main\" style=\"width: 100%;height: 400px\"></div>\r\n        </el-card>\r\n      </el-col>\r\n    </el-row>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport * as echarts from \"echarts\"\r\n\r\nexport default {\r\n  name: \"Home\",\r\n  data() {\r\n    return {\r\n      user: JSON.parse(localStorage.getItem('user') || '{}'),\r\n      activeNames: [0],\r\n      notices: []\r\n    }\r\n  },\r\n  created() {\r\n    this.loadNotice()\r\n  },\r\n  mounted() {\r\n    this.$request.get('/goods/echarts').then(res => {\r\n      this.initPie(res.data)\r\n    })\r\n  },\r\n  methods: {\r\n    handleChange(val) {\r\n      console.log(val);\r\n    },\r\n    loadNotice(){\r\n      this.$request.get('/notice/selectAll').then(res => {\r\n        this.notices = res.data\r\n      })\r\n    },\r\n    initPie(data){\r\n      let chartDom = document.getElementById('main');\r\n      let myChart = echarts.init(chartDom);\r\n      let option;\r\n\r\n      option = {\r\n        title: {\r\n          text: '商品销量统计',\r\n          subtext: '饼图',\r\n          left: 'center'\r\n        },\r\n        tooltip: {\r\n          trigger: 'item'\r\n        },\r\n        series: [\r\n          {\r\n            type: 'pie',\r\n            radius: '60%',\r\n            data: data,\r\n            emphasis: {\r\n              itemStyle: {\r\n                shadowBlur: 10,\r\n                shadowOffsetX: 0,\r\n                shadowColor: 'rgba(0, 0, 0, 0.5)'\r\n              }\r\n            }\r\n          }\r\n        ]\r\n      };\r\n\r\n      option && myChart.setOption(option);\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.text {\r\n  font-size: 14px;\r\n}\r\n\r\n.item {\r\n  margin-bottom: 18px;\r\n}\r\n\r\n.clearfix:before,\r\n.clearfix:after {\r\n  display: table;\r\n  content: \"\";\r\n}\r\n.clearfix:after {\r\n  clear: both\r\n}\r\n\r\n\r\n</style>\r\n"],"mappings":"AAoCA,YAAAA,OAAA;AAEA;EACAC,IAAA;EACAC,KAAA;IACA;MACAC,IAAA,EAAAC,IAAA,CAAAC,KAAA,CAAAC,YAAA,CAAAC,OAAA;MACAC,WAAA;MACAC,OAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,UAAA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA,CAAAC,GAAA,mBAAAC,IAAA,CAAAC,GAAA;MACA,KAAAC,OAAA,CAAAD,GAAA,CAAAd,IAAA;IACA;EACA;EACAgB,OAAA;IACAC,aAAAC,GAAA;MACAC,OAAA,CAAAC,GAAA,CAAAF,GAAA;IACA;IACAT,WAAA;MACA,KAAAE,QAAA,CAAAC,GAAA,sBAAAC,IAAA,CAAAC,GAAA;QACA,KAAAP,OAAA,GAAAO,GAAA,CAAAd,IAAA;MACA;IACA;IACAe,QAAAf,IAAA;MACA,IAAAqB,QAAA,GAAAC,QAAA,CAAAC,cAAA;MACA,IAAAC,OAAA,GAAA1B,OAAA,CAAA2B,IAAA,CAAAJ,QAAA;MACA,IAAAK,MAAA;MAEAA,MAAA;QACAC,KAAA;UACAC,IAAA;UACAC,OAAA;UACAC,IAAA;QACA;QACAC,OAAA;UACAC,OAAA;QACA;QACAC,MAAA,GACA;UACAC,IAAA;UACAC,MAAA;UACAnC,IAAA,EAAAA,IAAA;UACAoC,QAAA;YACAC,SAAA;cACAC,UAAA;cACAC,aAAA;cACAC,WAAA;YACA;UACA;QACA;MAEA;MAEAd,MAAA,IAAAF,OAAA,CAAAiB,SAAA,CAAAf,MAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}