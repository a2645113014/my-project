{"ast":null,"code":"export default {\n  name: \"GoodsDetail\",\n  data() {\n    return {\n      id: this.$route.query.id,\n      goods: {},\n      num: 1,\n      activeName: 'goods',\n      user: localStorage.getItem(\"user\") ? JSON.parse(localStorage.getItem(\"user\")) : {},\n      isCollect: false\n    };\n  },\n  created() {\n    this.loadGoods();\n  },\n  methods: {\n    loadGoods() {\n      this.$request.get('/goods/selectById?id=' + this.id).then(res => {\n        this.goods = res.data;\n        this.isCollect = this.goods.isCollect;\n      });\n    },\n    handleChange(value) {\n      this.num = value;\n      console.log(this.num);\n    },\n    handleClick(tab, event) {\n      console.log(tab, event);\n    },\n    collect() {\n      const data = {\n        goodsId: this.goods.id\n      };\n      this.$request.post('/collect/add', data).then(res => {\n        if (res.code == '200') {\n          this.$notify.success({\n            title: '成功',\n            message: '收藏成功',\n            showClose: false,\n            duration: 2000\n          });\n          this.isCollect = true;\n        } else {\n          this.$notify.error({\n            title: '成功',\n            message: res.msg,\n            showClose: false,\n            duration: 2000\n          });\n          this.isCollect = false;\n        }\n        this.loadGoods();\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","id","$route","query","goods","num","activeName","user","localStorage","getItem","JSON","parse","isCollect","created","loadGoods","methods","$request","get","then","res","handleChange","value","console","log","handleClick","tab","event","collect","goodsId","post","code","$notify","success","title","message","showClose","duration","error","msg"],"sources":["src/views/front/GoodsDetail.vue"],"sourcesContent":["<template>\r\n  <div style=\"width: 60%;min-height: 90vh;margin: 10px auto\">\r\n    <div style=\"display: flex\">\r\n      <div style=\"flex: 4\">\r\n        <el-image v-if=\"goods.cover\" style=\"width: 400px; height: 300px\" :src=\"goods.cover\" fit=\"cover\" :preview-src-list=\"[goods.cover]\"></el-image>\r\n      </div>\r\n      <div style=\"flex: 6\">\r\n        <div style=\"padding: 0 15px\">\r\n          <b style=\"font-size: 20px;color: #303133;\">{{goods.name}}</b>\r\n        </div>\r\n        <div style=\"padding: 0 15px;margin-top: 10px;\">\r\n          <p style=\"font-size: 11px;color: #606266;line-height: 17px;\">{{goods.descr}}</p>\r\n          <div style=\"border-bottom: 1px dashed #eaeaea;margin-top: 10px\"></div>\r\n        </div>\r\n        <div style=\"display: flex;padding: 0 15px;margin-top: 20px;align-items: center\">\r\n          <div>\r\n            <span style=\"font-size: 11px;color: #606266\">价格：</span>\r\n            <span style=\"font-size: 17px;color: #ff6700;font-weight: bold\">￥{{goods.price}}</span>\r\n          </div>\r\n          <div style=\"margin-left: 20px\">\r\n            <span style=\"font-size: 11px;color: #606266\">库存：{{goods.store}}</span>\r\n          </div>\r\n          <div style=\"margin-left: 20px\">\r\n            <span style=\"font-size: 11px;color: #606266\">累计热销：{{goods.sales}}</span>\r\n          </div>\r\n        </div>\r\n        <div style=\"padding: 0 15px;margin-top: 20px\">\r\n          <span style=\"font-size: 11px;color: #606266\">上架时间：{{goods.date}}</span>\r\n        </div>\r\n        <div style=\"display: flex;padding: 0 15px;margin-top: 15px;gap: 20px\">\r\n          <div>\r\n            <el-input-number v-model=\"num\" @change=\"handleChange\" :min=\"1\" :max=\"10\" label=\"描述文字\"></el-input-number>\r\n          </div>\r\n          <div>\r\n            <el-button type=\"primary\" style=\"width: 180px\">立即购买</el-button>\r\n          </div>\r\n          <div>\r\n            <el-button :type=\"isCollect ? 'danger' : 'warning'\" style=\"width: 180px\" @click=\"collect\">{{isCollect ? '已收藏' : '收藏'}}</el-button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div style=\"margin-top: 30px\">\r\n      <el-card>\r\n        <el-tabs v-model=\"activeName\" type=\"card\" @tab-click=\"handleClick\">\r\n          <el-tab-pane label=\"详细介绍\" name=\"goods\">\r\n            <div class=\"w-e-text\" v-html=\"goods.content\"></div>\r\n          </el-tab-pane>\r\n          <el-tab-pane label=\"购买须知\" name=\"notice\">\r\n            <div style=\"padding: 25px;\">\r\n              <h3 style=\"color: #333;margin: 15px 0;\">购买说明</h3>\r\n              <div>\r\n                <div style=\"margin: 10px 0;color: #666;\">1、正品保证</div>\r\n                <div style=\"margin: 10px 0;color: #666;\">2、7天无理由退货</div>\r\n                <div style=\"margin: 10px 0;color: #666;\">3、全国包邮</div>\r\n                <div style=\"margin: 10px 0;color: #666;\">4、售后无忧</div>\r\n              </div>\r\n            </div>\r\n          </el-tab-pane>\r\n        </el-tabs>\r\n      </el-card>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"GoodsDetail\",\r\n  data(){\r\n    return{\r\n      id: this.$route.query.id,\r\n      goods: {},\r\n      num: 1,\r\n      activeName: 'goods',\r\n      user: localStorage.getItem(\"user\") ? JSON.parse(localStorage.getItem(\"user\")) : {},\r\n      isCollect: false\r\n    }\r\n  },\r\n  created() {\r\n    this.loadGoods()\r\n  },\r\n  methods:{\r\n    loadGoods(){\r\n      this.$request.get('/goods/selectById?id=' + this.id).then(res => {\r\n        this.goods = res.data\r\n        this.isCollect = this.goods.isCollect\r\n      })\r\n    },\r\n    handleChange(value) {\r\n      this.num = value;\r\n      console.log(this.num)\r\n    },\r\n    handleClick(tab, event) {\r\n      console.log(tab, event);\r\n    },\r\n    collect(){\r\n      const data = {goodsId: this.goods.id}\r\n      this.$request.post('/collect/add',data).then(res => {\r\n        if (res.code == '200'){\r\n          this.$notify.success({title: '成功', message: '收藏成功', showClose: false, duration: 2000});\r\n          this.isCollect = true\r\n        } else {\r\n          this.$notify.error({title: '成功', message: res.msg, showClose: false, duration: 2000});\r\n          this.isCollect = false\r\n        }\r\n        this.loadGoods()\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAmEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,EAAA,OAAAC,MAAA,CAAAC,KAAA,CAAAF,EAAA;MACAG,KAAA;MACAC,GAAA;MACAC,UAAA;MACAC,IAAA,EAAAC,YAAA,CAAAC,OAAA,WAAAC,IAAA,CAAAC,KAAA,CAAAH,YAAA,CAAAC,OAAA;MACAG,SAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAD,UAAA;MACA,KAAAE,QAAA,CAAAC,GAAA,gCAAAhB,EAAA,EAAAiB,IAAA,CAAAC,GAAA;QACA,KAAAf,KAAA,GAAAe,GAAA,CAAAnB,IAAA;QACA,KAAAY,SAAA,QAAAR,KAAA,CAAAQ,SAAA;MACA;IACA;IACAQ,aAAAC,KAAA;MACA,KAAAhB,GAAA,GAAAgB,KAAA;MACAC,OAAA,CAAAC,GAAA,MAAAlB,GAAA;IACA;IACAmB,YAAAC,GAAA,EAAAC,KAAA;MACAJ,OAAA,CAAAC,GAAA,CAAAE,GAAA,EAAAC,KAAA;IACA;IACAC,QAAA;MACA,MAAA3B,IAAA;QAAA4B,OAAA,OAAAxB,KAAA,CAAAH;MAAA;MACA,KAAAe,QAAA,CAAAa,IAAA,iBAAA7B,IAAA,EAAAkB,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAW,IAAA;UACA,KAAAC,OAAA,CAAAC,OAAA;YAAAC,KAAA;YAAAC,OAAA;YAAAC,SAAA;YAAAC,QAAA;UAAA;UACA,KAAAxB,SAAA;QACA;UACA,KAAAmB,OAAA,CAAAM,KAAA;YAAAJ,KAAA;YAAAC,OAAA,EAAAf,GAAA,CAAAmB,GAAA;YAAAH,SAAA;YAAAC,QAAA;UAAA;UACA,KAAAxB,SAAA;QACA;QACA,KAAAE,SAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}