{"ast":null,"code":"export default {\n  name: \"Goods\",\n  data() {\n    const categoryId = this.$route.query.selectedCategoryId;\n    return {\n      types: [],\n      selectedCategoryId: categoryId ? parseInt(categoryId, 10) : 0,\n      total: 0,\n      pageNum: 1,\n      pageSize: 8,\n      keyboard: '',\n      goods: []\n    };\n  },\n  created() {\n    this.loadType();\n    this.loadGoods();\n  },\n  methods: {\n    loadType() {\n      this.$request.get('/type/selectAll').then(res => {\n        this.types = res.data;\n      });\n    },\n    loadGoods() {\n      console.log(this.$route.query.selectedCategoryId);\n      this.$request.get(\"/goods/selectPage/type\", {\n        params: {\n          pageNum: this.pageNum,\n          pageSize: this.pageSize,\n          name: this.keyboard,\n          typeId: this.selectedCategoryId\n        }\n      }).then(res => {\n        this.goods = res.data?.records;\n        this.total = res.data?.total;\n      });\n    },\n    handleAllClick() {\n      this.selectedCategoryId = 0;\n      this.$router.replace({\n        query: {\n          ...this.$route.query,\n          selectedCategoryId: 0\n        }\n      });\n      this.loadGoods();\n    },\n    handleCategoryClick(category) {\n      this.selectedCategoryId = category.id;\n      this.$router.replace({\n        query: {\n          ...this.$route.query,\n          selectedCategoryId: category.id\n        }\n      });\n      this.loadGoods();\n    },\n    handleCurrentChange(pageNum) {\n      this.pageNum = pageNum;\n      this.loadGoods();\n    }\n  }\n};","map":{"version":3,"names":["name","data","categoryId","$route","query","selectedCategoryId","types","parseInt","total","pageNum","pageSize","keyboard","goods","created","loadType","loadGoods","methods","$request","get","then","res","console","log","params","typeId","records","handleAllClick","$router","replace","handleCategoryClick","category","id","handleCurrentChange"],"sources":["src/views/front/Goods.vue"],"sourcesContent":["<template>\r\n  <div style=\"margin: 10px auto;min-height: 90vh;width: 70%\">\r\n    <!--顶部+搜索框-->\r\n    <div style=\"display: flex;justify-content: space-between;align-items: center\">\r\n      <div>\r\n        <h1 style=\"border-left: 5px solid #ff6700;padding-left: 7px;font-size: 22px;color:#303133;\">热卖商品</h1>\r\n      </div>\r\n      <div>\r\n        <input v-model='keyboard' type=\"text\" placeholder=\"请输入搜索商品名称\" class=\"search-input\" @keyup.enter=\"loadGoods\"/>\r\n        <el-button class=\"search-button\" @click=\"loadGoods\">\r\n          <i class=\"search-icon\">🔍</i>\r\n        </el-button>\r\n      </div>\r\n    </div>\r\n\r\n    <!--分类按钮-->\r\n    <div style=\"margin-top: 15px\">\r\n      <div class=\"type-group\">\r\n        <el-button type=\"primary\" :class=\"{ 'type-selected': selectedCategoryId === 0 }\" @click=\"handleAllClick\">全部</el-button>\r\n        <el-button type=\"primary\" v-for=\"(category,index) in types\" :key=\"index\" :class=\"{ 'type-selected': selectedCategoryId === category.id }\" @click=\"handleCategoryClick(category)\">\r\n          {{ category.name }}\r\n        </el-button>\r\n      </div>\r\n    </div>\r\n    <div>\r\n      <el-row :gutter=\"20\" v-if=\"goods.length > 0\">\r\n        <el-col :span=\"6\" v-for=\"(item,index) in goods\" :key=\"index\" style=\"margin-top: 10px\">\r\n          <el-card :body-style=\"{ padding: '0px' }\" class=\"card-item\">\r\n            <img :src=\"item.cover\" alt=\"\" style=\"width: 100%;height: 200px\">\r\n            <div style=\"padding: 10px\">\r\n              <div style=\"margin-top: 3px;font-size: 13px\">\r\n                {{item.name}}\r\n              </div>\r\n              <div style=\"margin-top: 5px;font-size: 11px;color: #909399;white-space: nowrap;overflow: hidden;text-overflow: ellipsis;\">\r\n                {{item.descr}}\r\n              </div>\r\n              <div style=\"display: flex;justify-content: space-between;align-items: center;margin-top: 10px\">\r\n                <div style=\"font-size: 20px;color: #FFA500;font-weight: 600\">\r\n                  ￥{{item.price}}\r\n                </div>\r\n                <div style=\"font-size:11px;color: #909399;\">\r\n                  累计热销：{{item.sales}}\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n      </el-row>\r\n      <div v-if=\"total > 0\" style=\"margin-top: 20px; text-align: right;\">\r\n        <el-pagination\r\n            @current-change=\"handleCurrentChange\"\r\n            :current-page=\"pageNum\"\r\n            :page-sizes=\"[8, 16, 32]\"\r\n            :page-size=\"pageSize\"\r\n            layout=\"total, prev, pager, next, jumper\"\r\n            :total=\"total\"\r\n            background\r\n        ></el-pagination>\r\n      </div>\r\n    </div>\r\n\r\n    <div v-if=\"goods.length == 0\">\r\n      <el-empty :image-size=\"300\" :image=\"require('@/assets/logo.svg')\" description=\"没有商品哟~\"></el-empty>    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Goods\",\r\n  data() {\r\n    const categoryId = this.$route.query.selectedCategoryId;\r\n    return {\r\n      types: [],\r\n      selectedCategoryId: categoryId ? parseInt(categoryId, 10) : 0,\r\n      total: 0,\r\n      pageNum: 1,\r\n      pageSize: 8,\r\n      keyboard: '',\r\n      goods: [],\r\n    }\r\n  },\r\n  created() {\r\n    this.loadType()\r\n    this.loadGoods()\r\n  },\r\n  methods:{\r\n    loadType(){\r\n      this.$request.get('/type/selectAll').then(res => {\r\n        this.types = res.data\r\n      })\r\n    },\r\n    loadGoods(){\r\n      console.log(this.$route.query.selectedCategoryId)\r\n      this.$request.get(\"/goods/selectPage/type\", {\r\n        params: {\r\n          pageNum: this.pageNum,\r\n          pageSize: this.pageSize,\r\n          name: this.keyboard,\r\n          typeId: this.selectedCategoryId\r\n        }\r\n      }).then(res => {\r\n        this.goods = res.data?.records\r\n        this.total = res.data?.total\r\n      })\r\n    },\r\n    handleAllClick() {\r\n      this.selectedCategoryId = 0;\r\n      this.$router.replace({\r\n        query: { ...this.$route.query, selectedCategoryId: 0 }\r\n      })\r\n      this.loadGoods()\r\n    },\r\n    handleCategoryClick(category) {\r\n      this.selectedCategoryId = category.id;\r\n      this.$router.replace({\r\n        query: { ...this.$route.query, selectedCategoryId: category.id }\r\n      })\r\n      this.loadGoods()\r\n    },\r\n    handleCurrentChange(pageNum){\r\n      this.pageNum = pageNum;\r\n      this.loadGoods()\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.search-input{\r\n  padding: 14px 24px;\r\n  outline: none;\r\n  border: none;\r\n  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);\r\n  font-size: 10px;\r\n}\r\n\r\n.search-button{\r\n  padding: 14px 24px;\r\n  background: #ff6700;\r\n  border: none;\r\n}\r\n\r\n/* 分类标签组容器（可选，优化间距） */\r\n.type-group {\r\n  display: flex;\r\n  gap: 8px;\r\n  margin-bottom: 10px;\r\n}\r\n\r\n/* 选中状态样式 */\r\n.type-selected {\r\n  background-color: #ff6700 !important;\r\n  color: #fff !important;\r\n}\r\n\r\n/* 未选中状态 hover效果 */\r\n.type-group .el-button--primary:not(.type-selected):hover {\r\n  background-color: #ff6700 !important;\r\n  color: #fff !important;\r\n}\r\n\r\n/* 重置 ElementUI 主按钮默认样式 */\r\n.type-group .el-button--primary {\r\n  background-color: #fff;\r\n  border-color: #dcdfe6;\r\n  color: #606266;\r\n}\r\n\r\n.card-item:hover{\r\n  cursor: pointer;\r\n  transform: scale(1.03);\r\n}\r\n</style>"],"mappings":"AAmEA;EACAA,IAAA;EACAC,KAAA;IACA,MAAAC,UAAA,QAAAC,MAAA,CAAAC,KAAA,CAAAC,kBAAA;IACA;MACAC,KAAA;MACAD,kBAAA,EAAAH,UAAA,GAAAK,QAAA,CAAAL,UAAA;MACAM,KAAA;MACAC,OAAA;MACAC,QAAA;MACAC,QAAA;MACAC,KAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAF,SAAA;MACA,KAAAG,QAAA,CAAAC,GAAA,oBAAAC,IAAA,CAAAC,GAAA;QACA,KAAAd,KAAA,GAAAc,GAAA,CAAAnB,IAAA;MACA;IACA;IACAc,UAAA;MACAM,OAAA,CAAAC,GAAA,MAAAnB,MAAA,CAAAC,KAAA,CAAAC,kBAAA;MACA,KAAAY,QAAA,CAAAC,GAAA;QACAK,MAAA;UACAd,OAAA,OAAAA,OAAA;UACAC,QAAA,OAAAA,QAAA;UACAV,IAAA,OAAAW,QAAA;UACAa,MAAA,OAAAnB;QACA;MACA,GAAAc,IAAA,CAAAC,GAAA;QACA,KAAAR,KAAA,GAAAQ,GAAA,CAAAnB,IAAA,EAAAwB,OAAA;QACA,KAAAjB,KAAA,GAAAY,GAAA,CAAAnB,IAAA,EAAAO,KAAA;MACA;IACA;IACAkB,eAAA;MACA,KAAArB,kBAAA;MACA,KAAAsB,OAAA,CAAAC,OAAA;QACAxB,KAAA;UAAA,QAAAD,MAAA,CAAAC,KAAA;UAAAC,kBAAA;QAAA;MACA;MACA,KAAAU,SAAA;IACA;IACAc,oBAAAC,QAAA;MACA,KAAAzB,kBAAA,GAAAyB,QAAA,CAAAC,EAAA;MACA,KAAAJ,OAAA,CAAAC,OAAA;QACAxB,KAAA;UAAA,QAAAD,MAAA,CAAAC,KAAA;UAAAC,kBAAA,EAAAyB,QAAA,CAAAC;QAAA;MACA;MACA,KAAAhB,SAAA;IACA;IACAiB,oBAAAvB,OAAA;MACA,KAAAA,OAAA,GAAAA,OAAA;MACA,KAAAM,SAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}