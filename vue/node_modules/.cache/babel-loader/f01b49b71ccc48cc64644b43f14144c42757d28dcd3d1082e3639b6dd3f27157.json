{"ast":null,"code":"export default {\n  name: \"Goods\",\n  data() {\n    return {\n      collects: []\n    };\n  },\n  created() {\n    this.loadCollect();\n  },\n  methods: {\n    loadCollect() {\n      this.$request.get('/collect/myCollect').then(res => {\n        this.collects = res.data;\n      });\n    },\n    goPage(url) {\n      location.href = url;\n    },\n    del(row) {\n      this.$request.delete('/collect/delete?id=' + row.id).then(res => {\n        if (res.code == '200') {\n          this.$notify.success({\n            title: '成功',\n            message: '已取消收藏',\n            showClose: false,\n            duration: 2000\n          });\n        } else {\n          this.$notify.error({\n            title: '成功',\n            message: res.msg,\n            showClose: false,\n            duration: 2000\n          });\n        }\n        this.loadCollect();\n      });\n    }\n  }\n};","map":{"version":3,"names":["name","data","collects","created","loadCollect","methods","$request","get","then","res","goPage","url","location","href","del","row","delete","id","code","$notify","success","title","message","showClose","duration","error","msg"],"sources":["src/views/front/Collect.vue"],"sourcesContent":["<template>\r\n  <div style=\"margin: 10px auto;min-height: 90vh;width: 70%\">\r\n    <!--顶部+搜索框-->\r\n    <div style=\"display: flex;justify-content: space-between;align-items: center\">\r\n      <div>\r\n        <h1 style=\"border-left: 5px solid #ff6700;padding-left: 7px;font-size: 22px;color:#303133;\">我的收藏</h1>\r\n      </div>\r\n    </div>\r\n\r\n    <div>\r\n      <el-row :gutter=\"20\" v-if=\"collects.length > 0\">\r\n        <el-col :span=\"6\" v-for=\"(item,index) in collects\" :key=\"index\" style=\"margin-top: 10px\">\r\n          <el-card :body-style=\"{ padding: '0px' }\" class=\"card-item\">\r\n            <img :src=\"item.goods.cover\" alt=\"\" style=\"width: 100%;height: 200px\" @click=\"goPage('/front/goodsDetail?id=' + item.goodsId)\">\r\n            <div style=\"padding: 10px\" >\r\n              <div style=\"margin-top: 3px;font-size: 13px\" @click=\"goPage('/front/goodsDetail?id=' + item.goodsId)\">\r\n                {{item.goods.name}}\r\n              </div>\r\n              <div style=\"margin-top: 5px;font-size: 11px;color: #909399;white-space: nowrap;overflow: hidden;text-overflow: ellipsis;\" @click=\"goPage('/front/goodsDetail?id=' + item.goodsId)\">\r\n                {{item.goods.descr}}\r\n              </div>\r\n              <div style=\"display: flex;justify-content: space-between;align-items: center;margin-top: 10px\">\r\n                <div style=\"font-size: 20px;color: #FFA500;font-weight: 600\">\r\n                  ￥{{item.goods.price}}\r\n                </div>\r\n\r\n                <div>\r\n                  <el-button type=\"text\" style=\"color: orangered\" @click=\"del(item)\">取消收藏</el-button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </el-card>\r\n        </el-col>\r\n      </el-row>\r\n    </div>\r\n\r\n    <div v-if=\"collects.length == 0\">\r\n      <el-empty :image-size=\"300\" :image=\"require('@/assets/enpty.svg')\" description=\"您还未收藏哟~\"></el-empty>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"Goods\",\r\n  data(){\r\n    return{\r\n      collects: [],\r\n    }\r\n  },\r\n  created() {\r\n    this.loadCollect()\r\n  },\r\n  methods:{\r\n    loadCollect(){\r\n      this.$request.get('/collect/myCollect').then(res => {\r\n        this.collects = res.data\r\n      })\r\n    },\r\n    goPage(url){\r\n      location.href = url\r\n    },\r\n    del(row){\r\n      this.$request.delete('/collect/delete?id=' + row.id).then(res => {\r\n        if (res.code == '200'){\r\n          this.$notify.success({title: '成功', message: '已取消收藏', showClose: false, duration: 2000});\r\n        } else {\r\n          this.$notify.error({title: '成功', message: res.msg, showClose: false, duration: 2000});\r\n        }\r\n        this.loadCollect()\r\n      })\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n.card-item:hover{\r\n  cursor: pointer;\r\n  transform: scale(1.03);\r\n}\r\n</style>"],"mappings":"AA2CA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,WAAA;EACA;EACAC,OAAA;IACAD,YAAA;MACA,KAAAE,QAAA,CAAAC,GAAA,uBAAAC,IAAA,CAAAC,GAAA;QACA,KAAAP,QAAA,GAAAO,GAAA,CAAAR,IAAA;MACA;IACA;IACAS,OAAAC,GAAA;MACAC,QAAA,CAAAC,IAAA,GAAAF,GAAA;IACA;IACAG,IAAAC,GAAA;MACA,KAAAT,QAAA,CAAAU,MAAA,yBAAAD,GAAA,CAAAE,EAAA,EAAAT,IAAA,CAAAC,GAAA;QACA,IAAAA,GAAA,CAAAS,IAAA;UACA,KAAAC,OAAA,CAAAC,OAAA;YAAAC,KAAA;YAAAC,OAAA;YAAAC,SAAA;YAAAC,QAAA;UAAA;QACA;UACA,KAAAL,OAAA,CAAAM,KAAA;YAAAJ,KAAA;YAAAC,OAAA,EAAAb,GAAA,CAAAiB,GAAA;YAAAH,SAAA;YAAAC,QAAA;UAAA;QACA;QACA,KAAApB,WAAA;MACA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}