{"ast":null,"code":"export default {\n  name: \"GoodsDetail\",\n  data() {\n    return {\n      id: this.$route.query.id,\n      goods: {},\n      num: 1,\n      activeName: 'goods'\n    };\n  },\n  created() {\n    this.loadGoods();\n  },\n  methods: {\n    loadGoods() {\n      this.$request.get('/goods/selectById?id=' + this.id).then(res => {\n        this.goods = res.data;\n      });\n    },\n    handleChange(value) {\n      this.num = value;\n      console.log(this.num);\n    },\n    handleClick(tab, event) {\n      console.log(tab, event);\n    }\n  }\n};","map":{"version":3,"names":["name","data","id","$route","query","goods","num","activeName","created","loadGoods","methods","$request","get","then","res","handleChange","value","console","log","handleClick","tab","event"],"sources":["src/views/front/GoodsDetail.vue"],"sourcesContent":["<template>\r\n  <div style=\"width: 60%;min-height: 90vh;margin: 10px auto\">\r\n    <div style=\"display: flex\">\r\n      <div style=\"flex: 4\">\r\n        <el-image style=\"width: 400px; height: 300px\" :src=\"goods.cover\" fit=\"cover\" :preview-src-list=\"[goods.cover]\"></el-image>\r\n      </div>\r\n      <div style=\"flex: 6\">\r\n        <div style=\"padding: 0 15px\">\r\n          <b style=\"font-size: 20px;color: #303133;\">{{goods.name}}</b>\r\n        </div>\r\n        <div style=\"padding: 0 15px;margin-top: 10px;\">\r\n          <p style=\"font-size: 11px;color: #606266;line-height: 17px;\">{{goods.descr}}</p>\r\n          <div style=\"border-bottom: 1px dashed #eaeaea;margin-top: 10px\"></div>\r\n        </div>\r\n        <div style=\"display: flex;padding: 0 15px;margin-top: 20px;align-items: center\">\r\n          <div>\r\n            <span style=\"font-size: 11px;color: #606266\">价格：</span>\r\n            <span style=\"font-size: 17px;color: #ff6700;font-weight: bold\">￥{{goods.price}}</span>\r\n          </div>\r\n          <div style=\"margin-left: 20px\">\r\n            <span style=\"font-size: 11px;color: #606266\">库存：{{goods.store}}</span>\r\n          </div>\r\n          <div style=\"margin-left: 20px\">\r\n            <span style=\"font-size: 11px;color: #606266\">累计热销：{{goods.sales}}</span>\r\n          </div>\r\n        </div>\r\n        <div style=\"padding: 0 15px;margin-top: 20px\">\r\n          <span style=\"font-size: 11px;color: #606266\">上架时间：{{goods.date}}</span>\r\n        </div>\r\n        <div style=\"display: flex;padding: 0 15px;margin-top: 15px;gap: 20px\">\r\n          <div>\r\n            <el-input-number v-model=\"num\" @change=\"handleChange\" :min=\"1\" :max=\"10\" label=\"描述文字\"></el-input-number>\r\n          </div>\r\n          <div>\r\n            <el-button type=\"primary\" style=\"width: 180px\">立即购买</el-button>\r\n          </div>\r\n          <div>\r\n            <el-button type=\"warning\" style=\"width: 180px\">收藏</el-button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n\r\n    <div style=\"margin-top: 30px\">\r\n      <el-card>\r\n        <el-tabs v-model=\"activeName\" type=\"card\" @tab-click=\"handleClick\">\r\n          <el-tab-pane label=\"详细介绍\" name=\"goods\">\r\n            <div class=\"w-e-text\" v-html=\"goods.content\"></div>\r\n          </el-tab-pane>\r\n          <el-tab-pane label=\"购买须知\" name=\"notice\">\r\n            <div style=\"padding: 25px;\">\r\n              <h3 style=\"color: #333;margin: 15px 0;\">购买说明</h3>\r\n              <div>\r\n                <div style=\"margin: 10px 0;color: #666;\">1、正品保证</div>\r\n                <div style=\"margin: 10px 0;color: #666;\">2、7天无理由退货</div>\r\n                <div style=\"margin: 10px 0;color: #666;\">3、全国包邮</div>\r\n                <div style=\"margin: 10px 0;color: #666;\">4、售后无忧</div>\r\n              </div>\r\n            </div>\r\n          </el-tab-pane>\r\n        </el-tabs>\r\n      </el-card>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  name: \"GoodsDetail\",\r\n  data(){\r\n    return{\r\n      id: this.$route.query.id,\r\n      goods: {},\r\n      num: 1,\r\n      activeName: 'goods'\r\n    }\r\n  },\r\n  created() {\r\n    this.loadGoods()\r\n  },\r\n  methods:{\r\n    loadGoods(){\r\n      this.$request.get('/goods/selectById?id=' + this.id).then(res => {\r\n        this.goods = res.data\r\n      })\r\n    },\r\n    handleChange(value) {\r\n      this.num = value;\r\n      console.log(this.num)\r\n    },\r\n    handleClick(tab, event) {\r\n      console.log(tab, event);\r\n    }\r\n  }\r\n}\r\n</script>\r\n\r\n<style scoped>\r\n\r\n</style>"],"mappings":"AAmEA;EACAA,IAAA;EACAC,KAAA;IACA;MACAC,EAAA,OAAAC,MAAA,CAAAC,KAAA,CAAAF,EAAA;MACAG,KAAA;MACAC,GAAA;MACAC,UAAA;IACA;EACA;EACAC,QAAA;IACA,KAAAC,SAAA;EACA;EACAC,OAAA;IACAD,UAAA;MACA,KAAAE,QAAA,CAAAC,GAAA,gCAAAV,EAAA,EAAAW,IAAA,CAAAC,GAAA;QACA,KAAAT,KAAA,GAAAS,GAAA,CAAAb,IAAA;MACA;IACA;IACAc,aAAAC,KAAA;MACA,KAAAV,GAAA,GAAAU,KAAA;MACAC,OAAA,CAAAC,GAAA,MAAAZ,GAAA;IACA;IACAa,YAAAC,GAAA,EAAAC,KAAA;MACAJ,OAAA,CAAAC,GAAA,CAAAE,GAAA,EAAAC,KAAA;IACA;EACA;AACA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}